# xchat-bot-starter-pro — environment configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Required: X App credentials ──────────────────────────────────────────────
XCHAT_CONSUMER_KEY=your_consumer_key_here
XCHAT_CONSUMER_SECRET=your_consumer_secret_here

# ── Required for Activity Stream (xchat run --transport stream) ───────────────
# App Bearer Token — get it from developer.x.com → your app → Keys and Tokens
# Used to authenticate the persistent stream connection (read-only).
XCHAT_BEARER_TOKEN=

# ── Required for sending DM replies (set after `xchat auth login`) ────────────
# OAuth 2.0 user access token — produced by the interactive login flow.
# Run: xchat auth login
XCHAT_USER_ACCESS_TOKEN=
XCHAT_USER_REFRESH_TOKEN=

# ── Transport mode ────────────────────────────────────────────────────────────
# "stream"  = persistent HTTP connection to X (default, no public URL needed)
# "webhook" = X POSTs events to your server (requires public HTTPS URL)
XCHAT_TRANSPORT_MODE=stream

# ── Webhook settings (only needed for transport_mode=webhook) ─────────────────
# XCHAT_WEBHOOK_HOST=0.0.0.0
# XCHAT_WEBHOOK_PORT=8080
# XCHAT_WEBHOOK_PATH=/webhook
# XCHAT_WEBHOOK_PUBLIC_URL=https://your-domain.com  # must be HTTPS

# ── OAuth 2.0 redirect URI ────────────────────────────────────────────────────
# IMPORTANT: Use 127.0.0.1, NOT localhost. X treats them differently.
# Register this exact URL in X Developer Portal → your app → Callback URLs.
XCHAT_OAUTH_REDIRECT_URI=http://127.0.0.1:7171/callback

# ── Crypto mode ───────────────────────────────────────────────────────────────
# "stub" = no real keys needed (dev/test, default)
# "real" = requires state.json from `xchat unlock` (EXPERIMENTAL: chat-xdk not yet stable)
XCHAT_CRYPTO_MODE=stub

# ── State file path ───────────────────────────────────────────────────────────
# XCHAT_STATE_FILE=state.json

# ── Logging ───────────────────────────────────────────────────────────────────
# XCHAT_LOG_LEVEL=INFO
# XCHAT_LOG_FORMAT=console  # "console" or "json"

# ── HTTP / retry ──────────────────────────────────────────────────────────────
# XCHAT_HTTP_TIMEOUT=30.0
# XCHAT_MAX_RETRIES=5
