# xchat-bot-starter-pro — environment configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Required: X App credentials ──────────────────────────────────────────────
XCHAT_CONSUMER_KEY=your_consumer_key_here
XCHAT_CONSUMER_SECRET=your_consumer_secret_here

# ── Optional: Pre-set OAuth tokens (set after `xchat auth login`) ─────────────
# XCHAT_ACCESS_TOKEN=
# XCHAT_ACCESS_TOKEN_SECRET=

# ── Transport mode ────────────────────────────────────────────────────────────
# "stream" = persistent HTTP connection (default)
# "webhook" = X POSTs events to your server
XCHAT_TRANSPORT_MODE=stream

# ── Webhook settings (only needed for transport_mode=webhook) ─────────────────
# XCHAT_WEBHOOK_HOST=0.0.0.0
# XCHAT_WEBHOOK_PORT=8080
# XCHAT_WEBHOOK_PATH=/webhook
# XCHAT_WEBHOOK_PUBLIC_URL=https://your-domain.com  # must be HTTPS

# ── OAuth redirect URI ────────────────────────────────────────────────────────
# IMPORTANT: Use 127.0.0.1, NOT localhost. X treats them differently.
# This must match exactly what you registered in the X Developer Portal.
XCHAT_OAUTH_REDIRECT_URI=http://127.0.0.1:7171/callback

# ── OAuth scopes (comma-separated, consult X developer docs) ─────────────────
# XCHAT_OAUTH_SCOPES=

# ── Crypto mode ───────────────────────────────────────────────────────────────
# "stub" = no real keys needed (dev/test)
# "real" = requires state.json from `xchat unlock` (EXPERIMENTAL: chat-xdk not yet stable)
XCHAT_CRYPTO_MODE=stub

# ── State file path ───────────────────────────────────────────────────────────
# XCHAT_STATE_FILE=state.json

# ── Logging ───────────────────────────────────────────────────────────────────
# XCHAT_LOG_LEVEL=INFO
# XCHAT_LOG_FORMAT=console  # "console" or "json"

# ── HTTP / retry ──────────────────────────────────────────────────────────────
# XCHAT_HTTP_TIMEOUT=30.0
# XCHAT_MAX_RETRIES=5
